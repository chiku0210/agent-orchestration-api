GROQ_API_KEY=
DATABASE_URL=
PORT=8080

# Comma-separated list of allowed web origins (Vercel domain + any custom domains).
# Example: CORS_ORIGINS=https://your-app.vercel.app,https://www.yourdomain.com
CORS_ORIGINS=http://localhost:3000

# Hard budgets (ms)
MARKET_PULSE_BUDGET_MS=240000
SPEC_FORGE_BUDGET_MS=300000

# Per-step timeouts (ms)
MARKET_PULSE_FACET_TIMEOUT_MS=90000
MARKET_PULSE_SYNTH_TIMEOUT_MS=120000
SPEC_FORGE_NODE_TIMEOUT_MS=180000

# Fast mode for SpecForge PRD
GROQ_SPEC_FORGE_FAST_MODE=1

# (Optional) reduce “repair JSON” / 429 waiting
GROQ_AGENT_MAX_PARSE_RETRIES=1
GROQ_AGENT_MAX_429_RETRIES=6

# -------------------------------
# Agent model routing + budgets
# -------------------------------
# Model selection (most specific wins):
# - AGENT_MODEL__<workflow>__<AgentRole>
# - AGENT_MODEL__<AgentRole>
#
# Timeouts (ms) (most specific wins):
# - AGENT_TIMEOUT_MS__<workflow>__<AgentRole>
# - AGENT_TIMEOUT_MS__<AgentRole>
#
# Max tokens (most specific wins):
# - AGENT_MAX_TOKENS__<workflow>__<AgentRole>
# - AGENT_MAX_TOKENS__<AgentRole>

# --- MarketPulse ---
AGENT_MODEL__market_pulse__TargetUserAgent=openai/gpt-oss-20b
AGENT_MODEL__market_pulse__AltSolutionsAgent=openai/gpt-oss-20b
AGENT_MODEL__market_pulse__PricingWillingnessAgent=openai/gpt-oss-20b
AGENT_MODEL__market_pulse__DistributionAgent=openai/gpt-oss-20b
AGENT_MODEL__market_pulse__RisksConstraintsAgent=openai/gpt-oss-20b
AGENT_MODEL__market_pulse__MarketPulseSynthesizer=llama-3.3-70b-versatile

# These default to MARKET_PULSE_FACET_TIMEOUT_MS / MARKET_PULSE_SYNTH_TIMEOUT_MS unless overridden.
AGENT_TIMEOUT_MS__market_pulse__TargetUserAgent=90000
AGENT_TIMEOUT_MS__market_pulse__AltSolutionsAgent=90000
AGENT_TIMEOUT_MS__market_pulse__PricingWillingnessAgent=90000
AGENT_TIMEOUT_MS__market_pulse__DistributionAgent=90000
AGENT_TIMEOUT_MS__market_pulse__RisksConstraintsAgent=90000
AGENT_TIMEOUT_MS__market_pulse__MarketPulseSynthesizer=120000

# Optional token caps (leave unset unless you want to clamp outputs)
# AGENT_MAX_TOKENS__market_pulse__MarketPulseSynthesizer=6000

# --- SpecForge ---
AGENT_MODEL__spec_forge__PRDAgent=openai/gpt-oss-20b
AGENT_MODEL__spec_forge__RiskAgent=openai/gpt-oss-safeguard-20b
AGENT_MODEL__spec_forge__ArchitectureAgent=llama-3.3-70b-versatile
AGENT_MODEL__spec_forge__DBAgent=llama-3.3-70b-versatile
AGENT_MODEL__spec_forge__BackendAgent=llama-3.3-70b-versatile
AGENT_MODEL__spec_forge__FrontendAgent=qwen/qwen3-32b

# These default to SPEC_FORGE_NODE_TIMEOUT_MS unless overridden.
AGENT_TIMEOUT_MS__spec_forge__PRDAgent=180000
AGENT_TIMEOUT_MS__spec_forge__RiskAgent=180000
AGENT_TIMEOUT_MS__spec_forge__ArchitectureAgent=180000
AGENT_TIMEOUT_MS__spec_forge__DBAgent=180000
AGENT_TIMEOUT_MS__spec_forge__BackendAgent=180000
AGENT_TIMEOUT_MS__spec_forge__FrontendAgent=180000

# Max token caps (helpful for big file bundles / HTML)
# AGENT_MAX_TOKENS__spec_forge__BackendAgent=6000
# AGENT_MAX_TOKENS__spec_forge__FrontendAgent=6000

# --- Router (optional, if/when you use it) ---
AGENT_MODEL__RouterAgent=openai/gpt-oss-20b
